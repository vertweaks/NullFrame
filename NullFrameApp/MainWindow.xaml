<Window x:Class="NullFrame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NULLFRAME — Windows Performance Optimizer"
        Width="1280" Height="820" MinWidth="960" MinHeight="600"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- 3-Column Grid Card Template -->
        <DataTemplate x:Key="TweakCardTemplate">
            <Border Background="{StaticResource Card}" BorderBrush="{StaticResource BorderBr}"
                    BorderThickness="1" CornerRadius="10" Margin="6" Padding="0"
                    SnapsToDevicePixels="True" MinHeight="160">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>    <!-- Content -->
                        <RowDefinition Height="Auto"/> <!-- Separator -->
                        <RowDefinition Height="Auto"/> <!-- Footer: warning + control -->
                    </Grid.RowDefinitions>

                    <!-- Card body -->
                    <StackPanel Grid.Row="0" Margin="18,16,18,10">
                        <!-- Title row -->
                        <DockPanel>
                            <TextBlock Text="{Binding DisplayName}"
                                       FontFamily="{StaticResource HeadingFont}"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource Text}"
                                       TextTrimming="CharacterEllipsis"
                                       DockPanel.Dock="Left"/>
                        </DockPanel>

                        <!-- Description -->
                        <TextBlock Text="{Binding Description}"
                                   FontSize="11" Foreground="{StaticResource TextDim}"
                                   TextWrapping="Wrap" Margin="0,6,0,0"
                                   MaxHeight="52" TextTrimming="CharacterEllipsis"/>

                        <!-- Status text (appears after action) -->
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{Binding StatusSuccess, Converter={StaticResource StatusBrush}}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Separator line -->
                    <Rectangle Grid.Row="1" Height="1" Fill="{StaticResource BorderBr}" Margin="14,0"/>

                    <!-- Footer: warning/no-warning + control -->
                    <DockPanel Grid.Row="2" Margin="18,10,18,12" LastChildFill="False">
                        <!-- Warning indicator (left side) -->
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left"
                                    VerticalAlignment="Center">
                            <!-- Warning icon -->
                            <TextBlock Text="⚠" FontSize="13"
                                       Foreground="{StaticResource Warning}"
                                       Margin="0,0,5,0"
                                       Visibility="{Binding HasWarning, Converter={StaticResource BoolVis}}"/>
                            <TextBlock Text="Warning" FontSize="11"
                                       Foreground="{StaticResource Warning}"
                                       Visibility="{Binding HasWarning, Converter={StaticResource BoolVis}}"/>
                            <!-- No warning -->
                            <TextBlock Text="No Warnings" FontSize="11"
                                       Foreground="{StaticResource TextDim}"
                                       Visibility="{Binding HasWarning, Converter={StaticResource InvBoolVis}}"/>
                        </StackPanel>

                        <!-- Control (right side) -->
                        <ToggleButton DockPanel.Dock="Right"
                                      Style="{StaticResource ToggleSwitch}"
                                      IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                      VerticalAlignment="Center"
                                      Visibility="{Binding Type, Converter={StaticResource ToggleVis}}"
                                      Click="OnToggleClicked"/>
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource ApplyButton}"
                                Content="APPLY  ▶" MinWidth="90" Height="30"
                                VerticalAlignment="Center"
                                Visibility="{Binding Type, Converter={StaticResource ApplyVis}}"
                                Click="OnApplyClicked"/>
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource ConfigButton}"
                                Content="CONFIGURE" MinWidth="90" Height="30"
                                VerticalAlignment="Center"
                                Visibility="{Binding Type, Converter={StaticResource PresetVis}}"
                                Click="OnConfigureClicked"/>
                    </DockPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════ SIDEBAR ═══════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource Panel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Logo -->
                    <RowDefinition Height="Auto"/>  <!-- Rule -->
                    <RowDefinition Height="Auto"/>  <!-- MODULES label -->
                    <RowDefinition Height="*"/>     <!-- Nav buttons -->
                    <RowDefinition Height="Auto"/>  <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,20,0,20">
                    <Border Width="38" Height="38" Background="{StaticResource NfRed}"
                            CornerRadius="6">
                        <TextBlock Text="NF" FontSize="16" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="{StaticResource HeadingFont}"/>
                    </Border>
                    <StackPanel Margin="10,1,0,0">
                        <TextBlock Text="NULL" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource Text}"
                                   FontFamily="{StaticResource HeadingFont}"
                                   LineHeight="22"/>
                        <TextBlock Text="FRAME" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource NfBright}"
                                   FontFamily="{StaticResource HeadingFont}"
                                   Margin="0,-3,0,0" LineHeight="22"/>
                    </StackPanel>
                </StackPanel>

                <!-- Divider -->
                <Rectangle Grid.Row="1" Height="1" Margin="16,0"
                           Fill="{StaticResource BorderMid}"/>

                <!-- MODULES label -->
                <TextBlock Grid.Row="2" Text="MODULES" FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource TextDim}" Margin="20,14,0,8"
                           FontFamily="{StaticResource HeadingFont}"/>

                <!-- Navigation buttons -->
                <StackPanel x:Name="NavPanel" Grid.Row="3" Margin="6,0,6,0"/>

                <!-- Footer -->
                <StackPanel Grid.Row="4" Margin="20,0,0,16">
                    <Rectangle Height="1" Margin="0,0,14,12"
                               Fill="{StaticResource BorderMid}"/>
                    <TextBlock FontSize="9" Foreground="{StaticResource TextDim}"
                               FontFamily="{StaticResource BodyFont}">
                        <Run Text="NULLFRAME  //  V1.0"/>
                        <LineBreak/>
                        <Run Text="RUN AS ADMINISTRATOR"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════ CONTENT AREA ═══════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="Auto"/>  <!-- Search bar -->
                <RowDefinition Height="*"/>     <!-- Tweak grid -->
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Grid.Row="0" Background="{StaticResource Panel}" Padding="28,16,28,14">
                <StackPanel>
                    <TextBlock x:Name="HeaderTitle" Text="CPU &amp; SYSTEM"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource Text}"
                               FontFamily="{StaticResource HeadingFont}"/>
                    <TextBlock x:Name="HeaderSubtitle" Text="Optimize CPU scheduling and system performance."
                               FontSize="12" Foreground="{StaticResource TextDim}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Search / Filter bar -->
            <Border Grid.Row="1" Background="{StaticResource Bg}" Padding="28,14,28,6">
                <DockPanel>
                    <TextBlock x:Name="HeaderCount" Text="19 TWEAKS"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextDim}"
                               FontFamily="{StaticResource HeadingFont}"
                               DockPanel.Dock="Right" VerticalAlignment="Center"
                               Margin="16,0,0,0"/>
                    <Border Background="{StaticResource Card}" CornerRadius="8"
                            BorderBrush="{StaticResource BorderBr}" BorderThickness="1"
                            Padding="0" MaxWidth="420" HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#x1F50D;" FontSize="13"
                                       Foreground="{StaticResource TextDim}"
                                       VerticalAlignment="Center" Margin="12,0,8,0"/>
                            <TextBox x:Name="SearchBox" Grid.Column="1"
                                     FontSize="12" Padding="4,8"
                                     Background="Transparent"
                                     Foreground="{StaticResource Text}"
                                     BorderThickness="0"
                                     CaretBrush="{StaticResource Text}"
                                     MinWidth="280"
                                     TextChanged="OnSearchChanged"/>
                        </Grid>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Scrollable tweak grid (3-column WrapPanel) -->
            <ScrollViewer x:Name="TweakScroller" Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{StaticResource Bg}">
                <ItemsControl x:Name="TweakList"
                              ItemTemplate="{StaticResource TweakCardTemplate}"
                              Margin="22,4,22,24">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <!-- Backup & Restore page (hidden by default, shown for Module 09) -->
            <ScrollViewer x:Name="BackupScroller" Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{StaticResource Bg}" Visibility="Collapsed">
                <StackPanel x:Name="BackupPanel" Margin="24,10,24,24"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>

<Window x:Class="NullFrame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NULLFRAME — Windows Performance Optimizer"
        Width="1180" Height="780" MinWidth="960" MinHeight="600"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Tweak Card DataTemplate -->
        <DataTemplate x:Key="TweakCardTemplate">
            <Border Margin="0,3" SnapsToDevicePixels="True">
                <Grid>
                    <!-- Red left accent bar -->
                    <Rectangle Width="3" HorizontalAlignment="Left" Fill="{StaticResource NfRed}"/>

                    <Border Background="{StaticResource Card}" BorderBrush="{StaticResource BorderBr}"
                            BorderThickness="1" Margin="3,0,0,0" Padding="0">
                        <Grid Margin="16,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>   <!-- Warning icon -->
                                <ColumnDefinition Width="*"/>      <!-- Name + Desc -->
                                <ColumnDefinition Width="Auto"/>   <!-- FREE badge -->
                                <ColumnDefinition Width="Auto"/>   <!-- Status -->
                                <ColumnDefinition Width="Auto"/>   <!-- Control -->
                            </Grid.ColumnDefinitions>

                            <!-- Warning icon -->
                            <TextBlock Grid.Column="0" Text="⚠" FontSize="16"
                                       Foreground="{StaticResource Warning}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"
                                       Visibility="{Binding HasWarning, Converter={StaticResource BoolVis}}"/>

                            <!-- Name + Description -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}"
                                           FontFamily="{StaticResource HeadingFont}"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="{StaticResource Text}"
                                           TextTransform="Uppercase"/>
                                <TextBlock Text="{Binding Description}"
                                           FontSize="11" Foreground="{StaticResource TextDim}"
                                           TextWrapping="Wrap" Margin="0,3,20,0"
                                           MaxWidth="560"/>
                            </StackPanel>

                            <!-- FREE badge -->
                            <Border Grid.Column="2" Background="#1A480E18" CornerRadius="2"
                                    Padding="8,3" Margin="0,0,12,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsFree, Converter={StaticResource BoolVis}}">
                                <TextBlock Text="FREE" FontSize="9" FontWeight="Bold"
                                           Foreground="{StaticResource NfBright}"/>
                            </Border>

                            <!-- Status text -->
                            <TextBlock Grid.Column="3" Text="{Binding StatusText}"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{Binding StatusSuccess, Converter={StaticResource StatusBrush}}"
                                       VerticalAlignment="Center" Margin="0,0,16,0"
                                       MinWidth="80" TextAlignment="Right"/>

                            <!-- Toggle switch (for Toggle type) -->
                            <ToggleButton Grid.Column="4"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                          VerticalAlignment="Center"
                                          Visibility="{Binding Type, Converter={StaticResource ToggleVis}}"
                                          Click="OnToggleClicked"/>

                            <!-- Apply button (for Apply type) -->
                            <Button Grid.Column="4"
                                    Style="{StaticResource ApplyButton}"
                                    Content="APPLY  ▶" MinWidth="100"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding Type, Converter={StaticResource ApplyVis}}"
                                    Click="OnApplyClicked"/>

                            <!-- Configure button (for Preset type) -->
                            <Button Grid.Column="4"
                                    Style="{StaticResource ConfigButton}"
                                    Content="CONFIGURE" MinWidth="100"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding Type, Converter={StaticResource PresetVis}}"
                                    Click="OnConfigureClicked"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════ SIDEBAR ═══════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource Panel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Red stripe -->
                    <RowDefinition Height="Auto"/>  <!-- Logo -->
                    <RowDefinition Height="Auto"/>  <!-- Rule -->
                    <RowDefinition Height="Auto"/>  <!-- MODULES label -->
                    <RowDefinition Height="*"/>     <!-- Nav buttons -->
                    <RowDefinition Height="Auto"/>  <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Red accent stripe -->
                <Rectangle Grid.Row="0" Height="3" Fill="{StaticResource NfRed}"/>

                <!-- Logo -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,20,0,16">
                    <!-- Logo mark (octagonal badge) -->
                    <Border Width="42" Height="42" Background="{StaticResource NfRed}"
                            CornerRadius="4">
                        <TextBlock Text="NF" FontSize="18" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="{StaticResource HeadingFont}"/>
                    </Border>
                    <StackPanel Margin="12,2,0,0">
                        <TextBlock Text="NULL" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource Text}"
                                   FontFamily="{StaticResource HeadingFont}"
                                   LineHeight="24"/>
                        <TextBlock Text="FRAME" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource NfBright}"
                                   FontFamily="{StaticResource HeadingFont}"
                                   Margin="0,-4,0,0" LineHeight="24"/>
                    </StackPanel>
                </StackPanel>

                <!-- Divider rule -->
                <Rectangle Grid.Row="2" Height="1" Margin="14,0"
                           Fill="{StaticResource BorderMid}"/>

                <!-- MODULES label -->
                <TextBlock Grid.Row="3" Text="MODULES" FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource TextDim}" Margin="20,12,0,8"
                           FontFamily="{StaticResource HeadingFont}"/>

                <!-- Navigation buttons -->
                <StackPanel x:Name="NavPanel" Grid.Row="4" Margin="0,0,0,0"/>

                <!-- Footer -->
                <StackPanel Grid.Row="5" Margin="20,0,0,14">
                    <Rectangle Height="1" Margin="0,0,14,10"
                               Fill="{StaticResource BorderMid}"/>
                    <TextBlock FontSize="9" Foreground="{StaticResource TextDim}"
                               FontFamily="{StaticResource BodyFont}">
                        <Run Text="NULLFRAME  //  V1.0"/>
                        <LineBreak/>
                        <Run Text="RUN AS ADMINISTRATOR"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════ CONTENT AREA ═══════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="*"/>     <!-- Tweak list -->
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Grid.Row="0" Background="{StaticResource Panel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3"/>   <!-- Red accent line -->
                        <RowDefinition Height="Auto"/> <!-- Eyebrow -->
                        <RowDefinition Height="Auto"/> <!-- Title -->
                    </Grid.RowDefinitions>

                    <Rectangle Grid.Row="0" Fill="{StaticResource NfRed}"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="26,12,0,4">
                        <TextBlock Text="◆" Foreground="{StaticResource NfBright}"
                                   FontSize="9" Margin="0,0,6,0"/>
                        <TextBlock x:Name="HeaderEyebrow" Text="NULLFRAME  //  MODULE 01"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource NfBright}"
                                   FontFamily="{StaticResource HeadingFont}"/>
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="26,0,26,14">
                        <TextBlock x:Name="HeaderTitle" Text="CPU &amp; SYSTEM"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource Text}"
                                   FontFamily="{StaticResource HeadingFont}"
                                   HorizontalAlignment="Left"/>
                        <TextBlock x:Name="HeaderCount" Text="13 TWEAKS AVAILABLE"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextDim}"
                                   FontFamily="{StaticResource HeadingFont}"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Scrollable tweak list -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{StaticResource Bg}">
                <ItemsControl x:Name="TweakList"
                              ItemTemplate="{StaticResource TweakCardTemplate}"
                              Margin="24,10,24,24">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
